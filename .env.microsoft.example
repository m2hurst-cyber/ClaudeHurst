# Microsoft Graph development configuration
# Copy these into .env locally. Do not commit real values.

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/microsoft_connection/callback

# Optional Teams destinations for future event routing
MICROSOFT_TEAMS_SALES_TEAM_ID=
MICROSOFT_TEAMS_SALES_CHANNEL_ID=
MICROSOFT_TEAMS_OPS_TEAM_ID=
MICROSOFT_TEAMS_OPS_CHANNEL_ID=
MICROSOFT_TEAMS_FINANCE_TEAM_ID=
MICROSOFT_TEAMS_FINANCE_CHANNEL_ID=
MICROSOFT_TEAMS_ADMIN_TEAM_ID=
MICROSOFT_TEAMS_ADMIN_CHANNEL_ID=
