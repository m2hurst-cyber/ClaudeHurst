<%= form_with model: company, class: "space-y-3 bg-white p-4 rounded shadow-sm border max-w-xl" do |f| %>
  <% if company.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm">
      <%= company.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div><%= f.label :name %><%= f.text_field :name, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :website %><%= f.text_field :website, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :industry %><%= f.text_field :industry, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :status %><%= f.select :status, Company::STATUSES, {}, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :owner_id, "Owner" %><%= f.collection_select :owner_id, User.active, :id, :display_name, { include_blank: true }, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :notes %><%= f.text_area :notes, rows: 3, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.submit class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %></div>
<% end %>
