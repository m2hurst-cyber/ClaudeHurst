<%= render "shared/operator_cockpit",
  title: @company.name,
  subtitle: "Control the customer relationship, commercial pipeline, and next operating step.",
  primary_action: link_to("+ Deal", new_company_deal_path(@company), class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-sm"),
  actions: [
    link_to("+ Contact", new_company_contact_path(@company), class: "rounded-xl border px-3 py-2 text-sm text-center"),
    link_to("+ Quote", new_quote_path(company_id: @company.id), class: "rounded-xl border px-3 py-2 text-sm text-center"),
    link_to("+ Product", new_company_product_path(@company), class: "rounded-xl border px-3 py-2 text-sm text-center"),
    link_to("+ Task", new_task_path(company_id: @company.id), class: "rounded-xl border px-3 py-2 text-sm text-center"),
    link_to("+ Reminder", new_reminder_path(company_id: @company.id), class: "rounded-xl border px-3 py-2 text-sm text-center"),
    link_to("Edit", edit_company_path(@company), class: "rounded-xl border px-3 py-2 text-sm text-center")
  ] %>

<div class="mb-4 grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="text-xs uppercase tracking-wide text-slate-500">Status</div>
    <div class="mt-2"><%= status_badge(@company.status) %></div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="text-xs uppercase tracking-wide text-slate-500">Owner</div>
    <div class="mt-1 text-sm font-medium text-slate-900"><%= @company.owner&.display_name || "Unassigned" %></div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="text-xs uppercase tracking-wide text-slate-500">Open deals</div>
    <div class="mt-1 text-2xl font-semibold text-slate-900"><%= @current_deals.size %></div>
  </div>
  <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="text-xs uppercase tracking-wide text-slate-500">Upcoming runs</div>
    <div class="mt-1 text-2xl font-semibold text-slate-900"><%= @upcoming_runs.size %></div>
  </div>
</div>

<div class="grid grid-cols-1 gap-4 xl:grid-cols-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-slate-900">Primary and secondary contacts</h2>
      <span class="text-xs text-slate-400"><%= @primary_contacts.size + @secondary_contacts.size %> contacts</span>
    </div>

    <div class="space-y-4">
      <div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">Primary</div>
        <% if @primary_contacts.any? %>
          <ul class="space-y-2 text-sm">
            <% @primary_contacts.each do |contact| %>
              <li class="rounded-xl border border-slate-200 p-3">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <%= link_to contact.display_name, contact, class: "font-medium text-sky-700 hover:underline" %>
                    <div class="text-xs text-slate-500"><%= contact.title.presence || "No title set" %></div>
                  </div>
                  <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-800">Primary</span>
                </div>
                <div class="mt-2 text-xs text-slate-500"><%= [contact.email, contact.phone].compact_blank.join(" · ").presence || "No contact details" %></div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-slate-400">No primary contact tagged yet.</p>
        <% end %>
      </div>

      <div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">Secondary</div>
        <% if @secondary_contacts.any? %>
          <ul class="divide-y text-sm">
            <% @secondary_contacts.each do |contact| %>
              <li class="flex items-center justify-between gap-3 py-2">
                <div>
                  <%= link_to contact.display_name, contact, class: "font-medium text-sky-700 hover:underline" %>
                  <div class="text-xs text-slate-500"><%= contact.title.presence || "No title set" %></div>
                </div>
                <div class="text-right text-xs text-slate-500"><%= [contact.email, contact.phone].compact_blank.join(" · ").presence || "No contact details" %></div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-slate-400">No secondary contacts yet.</p>
        <% end %>
      </div>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-slate-900">Current tasks and deals</h2>
      <span class="text-xs text-slate-400"><%= @current_tasks.size + @current_deals.size %> active items</span>
    </div>

    <div class="space-y-4">
      <div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">Deals</div>
        <% if @current_deals.any? %>
          <ul class="divide-y text-sm">
            <% @current_deals.each do |deal| %>
              <li class="flex items-center justify-between gap-3 py-2">
                <div>
                  <%= link_to deal.name, deal, class: "font-medium text-sky-700 hover:underline" %>
                  <div class="text-xs text-slate-500">Owner: <%= deal.owner&.display_name || "Unassigned" %></div>
                </div>
                <div class="text-right">
                  <div><%= status_badge(deal.stage) %></div>
                  <div class="mt-1 text-xs text-slate-500"><%= nice_date(deal.expected_close_on) %></div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-slate-400">No open deals for this company.</p>
        <% end %>
      </div>

      <div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">Tasks</div>
        <% if @current_tasks.any? %>
          <ul class="divide-y text-sm">
            <% @current_tasks.each do |task| %>
              <li class="flex items-center justify-between gap-3 py-2">
                <div>
                  <%= link_to task.title, task, class: "font-medium text-sky-700 hover:underline" %>
                  <div class="text-xs text-slate-500">Assignee: <%= task.assignee&.display_name || "Unassigned" %></div>
                </div>
                <div class="text-right text-xs text-slate-500">
                  <div><%= task.priority.humanize %></div>
                  <div><%= nice_date(task.due_on) %></div>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-slate-400">No open company tasks.</p>
        <% end %>
      </div>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-slate-900">Upcoming runs</h2>
      <span class="text-xs text-slate-400"><%= @upcoming_runs.size %> scheduled</span>
    </div>

    <% if @upcoming_runs.any? %>
      <ul class="divide-y text-sm">
        <% @upcoming_runs.each do |run| %>
          <li class="flex items-center justify-between gap-3 py-2">
            <div>
              <%= link_to run.number, run, class: "font-medium text-sky-700 hover:underline" %>
              <div class="text-xs text-slate-500"><%= run.product.display_name %> · <%= run.production_line.name %></div>
            </div>
            <div class="text-right text-xs text-slate-500">
              <div><%= status_badge(run.status) %></div>
              <div class="mt-1"><%= nice_datetime(run.scheduled_start) %></div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-slate-400">No upcoming runs tied to this company’s products.</p>
    <% end %>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-sm font-semibold text-slate-900">Tagged reminders</h2>
      <span class="text-xs text-slate-400"><%= @tagged_reminders.size %> reminders</span>
    </div>

    <% if @tagged_reminders.any? %>
      <ul class="divide-y text-sm">
        <% @tagged_reminders.each do |reminder| %>
          <li class="py-2">
            <div class="flex items-start justify-between gap-3">
              <div>
                <div class="font-medium text-slate-900"><%= reminder.message %></div>
                <div class="text-xs text-slate-500">Owner: <%= reminder.user.display_name %> · <%= reminder.channel.humanize %> · <%= reminder.recurrence.humanize %></div>
              </div>
              <div class="text-right text-xs text-slate-500">
                <div><%= nice_datetime(reminder.remind_at) %></div>
                <div><%= reminder.fired? ? "Fired" : "Pending" %></div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-slate-400">No reminders tagged to this company.</p>
    <% end %>
  </section>
</div>

<section class="mt-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
  <div class="mb-3 flex items-center justify-between">
    <h2 class="text-sm font-semibold text-slate-900">Recent activity</h2>
    <span class="text-xs text-slate-400"><%= @activities.size %> events</span>
  </div>

  <% if @activities.any? %>
    <ul class="divide-y text-sm">
      <% @activities.each do |activity| %>
        <li class="py-2">
          <div class="flex items-center justify-between gap-3">
            <div>
              <div class="font-medium text-slate-900"><%= activity.kind.humanize %></div>
              <div class="text-slate-500"><%= activity.body %></div>
            </div>
            <div class="text-xs text-slate-400"><%= nice_datetime(activity.occurred_at) %></div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-400">No recent activity logged for this company.</p>
  <% end %>
</section>
