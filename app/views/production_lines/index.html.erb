<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Production lines</h1>
  <%= link_to "+ New line", new_production_line_path, class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
</div>

<div class="bg-white rounded shadow-sm border overflow-x-auto">
  <table class="w-full text-sm">
    <thead class="bg-slate-100 text-slate-700">
      <tr>
        <th class="px-3 py-2 text-left">Code</th>
        <th class="px-3 py-2 text-left">Name</th>
        <th class="px-3 py-2 text-right">Hourly capacity</th>
        <th class="px-3 py-2 text-left">Active</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @lines.each do |line| %>
        <tr>
          <td class="px-3 py-2 font-mono text-xs"><%= link_to line.code, line, class: "text-sky-700 hover:underline" %></td>
          <td class="px-3 py-2"><%= line.name %></td>
          <td class="px-3 py-2 text-right"><%= line.hourly_capacity %></td>
          <td class="px-3 py-2"><%= line.active? ? "Yes" : "No" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
