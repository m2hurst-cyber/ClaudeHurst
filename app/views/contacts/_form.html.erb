<%= form_with(model: contact, url: (contact.new_record? ? company_contacts_path(contact.company) : contact_path(contact)),
              class: "space-y-3 bg-white p-4 rounded shadow-sm border max-w-xl") do |f| %>
  <% if contact.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm"><%= contact.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="grid grid-cols-2 gap-2">
    <div><%= f.label :first_name %><%= f.text_field :first_name, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :last_name %><%= f.text_field :last_name, class: "border rounded px-2 py-1 w-full" %></div>
  </div>
  <div><%= f.label :title %><%= f.text_field :title, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :email %><%= f.email_field :email, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :phone %><%= f.text_field :phone, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.check_box :primary %> <%= f.label :primary, "Primary contact" %></div>
  <div><%= f.submit class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %></div>
<% end %>
