<div class="flex justify-between items-start mb-4">
  <h1 class="text-2xl font-bold"><%= @contact.display_name %></h1>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_contact_path(@contact), class: "border px-3 py-1.5 rounded text-sm" %>
    <%= button_to "Delete", contact_path(@contact), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-600 text-white px-3 py-1.5 rounded text-sm" %>
  </div>
</div>
<div class="bg-white border rounded p-4 max-w-xl text-sm space-y-1">
  <div><strong>Company:</strong> <%= link_to @contact.company.name, @contact.company %></div>
  <div><strong>Title:</strong> <%= @contact.title %></div>
  <div><strong>Email:</strong> <%= @contact.email %></div>
  <div><strong>Phone:</strong> <%= @contact.phone %></div>
</div>
