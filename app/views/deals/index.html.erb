<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Deals</h1>
  <%= link_to "Pipeline view", pipeline_deals_path, class: "border px-3 py-1.5 rounded text-sm" %>
</div>
<div class="bg-white rounded shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-100"><tr>
      <th class="px-3 py-2 text-left">Name</th><th class="px-3 py-2 text-left">Company</th>
      <th class="px-3 py-2 text-left">Stage</th><th class="px-3 py-2 text-right">Amount</th>
      <th class="px-3 py-2 text-left">Owner</th><th class="px-3 py-2 text-left">Expected close</th>
    </tr></thead>
    <tbody class="divide-y">
      <% @deals.each do |d| %>
        <tr>
          <td class="px-3 py-2"><%= link_to d.name, d, class: "text-sky-700" %></td>
          <td class="px-3 py-2"><%= link_to d.company.name, d.company %></td>
          <td class="px-3 py-2"><%= status_badge d.stage %></td>
          <td class="px-3 py-2 text-right"><%= money(d.amount_cents) %></td>
          <td class="px-3 py-2"><%= d.owner&.display_name %></td>
          <td class="px-3 py-2"><%= nice_date(d.expected_close_on) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-3"><%== pagy_nav(@pagy) %></div>
