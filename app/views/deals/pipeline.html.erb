<h1 class="text-2xl font-bold mb-4">Pipeline</h1>
<div class="grid grid-cols-6 gap-3">
  <% @stages.each do |stage| %>
    <div class="bg-slate-100 rounded p-2 min-h-[400px]">
      <h2 class="font-semibold text-sm mb-2 flex items-center justify-between">
        <span><%= stage.humanize %></span>
        <span class="text-xs text-slate-500"><%= (@deals_by_stage[stage] || []).size %></span>
      </h2>
      <div class="space-y-2">
        <% (@deals_by_stage[stage] || []).each do |d| %>
          <div class="bg-white rounded border p-2 text-sm">
            <div class="font-medium"><%= link_to d.name, d, class: "text-sky-700" %></div>
            <div class="text-xs text-slate-500"><%= d.company.name %></div>
            <div class="text-xs"><%= money(d.amount_cents) %></div>
            <div class="mt-1 flex flex-wrap gap-1">
              <% (Deal::STAGES - [d.stage]).each do |s| %>
                <%= button_to s.split("_").first, advance_deal_path(d, stage: s),
                    class: "text-xs border px-1.5 py-0.5 rounded bg-slate-50 hover:bg-slate-200" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
