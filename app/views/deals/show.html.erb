<%= render "shared/operator_cockpit",
  title: @deal.name,
  subtitle: "Move the deal forward or capture activity.",
  primary_action: link_to("+ Activity", new_deal_activity_path(@deal), class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-sm"),
  actions: [
    link_to("+ Quote", new_quote_path(company_id: @deal.company_id, deal_id: @deal.id), class: "rounded-xl border px-3 py-2 text-sm text-center"),
    link_to("+ Task", new_task_path(deal_id: @deal.id), class: "rounded-xl border px-3 py-2 text-sm text-center"),
    link_to("Advance stage", advance_deal_path(@deal), data: { turbo_method: :post }, class: "rounded-xl border px-3 py-2 text-sm text-center"),
    link_to("View company", @deal.company, class: "rounded-xl border px-3 py-2 text-sm text-center")
  ] %>

<div class="bg-white border rounded p-4 mb-4 text-sm grid grid-cols-3 gap-2">
  <div><strong>Owner:</strong> <%= @deal.owner&.display_name %></div>
  <div><strong>Expected close:</strong> <%= nice_date(@deal.expected_close_on) %></div>
  <div><strong>Probability:</strong> <%= @deal.probability %>%</div>
</div>
<div class="bg-white border rounded p-4">
  <h2 class="font-semibold mb-2">Activity</h2>
  <ul class="text-sm divide-y">
    <% @activities.each do |a| %>
      <li class="py-1.5">
        <div class="flex justify-between"><strong><%= a.kind.humanize %></strong><span class="text-xs text-slate-400"><%= nice_datetime a.occurred_at %></span></div>
        <div class="text-slate-600"><%= a.body %></div>
      </li>
    <% end %>
  </ul>
</div>
