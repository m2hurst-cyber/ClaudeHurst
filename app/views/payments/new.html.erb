<h1 class="text-2xl font-bold mb-4">Record payment on Invoice <%= @invoice.number %></h1>

<%= form_with model: @payment, url: invoice_payments_path(@invoice), class: "space-y-3 bg-white p-4 rounded shadow-sm border max-w-xl" do |f| %>
  <% if @payment.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm">
      <%= @payment.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div class="text-sm text-slate-600">Invoice balance: <strong><%= money(@invoice.balance_cents) %></strong></div>
  <div><%= f.label :amount_cents, "Amount (cents)" %><%= f.number_field :amount_cents, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :received_on %><%= f.date_field :received_on, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :method %><%= f.select :method, Payment::METHODS, {}, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :reference %><%= f.text_field :reference, class: "border rounded px-2 py-1 w-full", placeholder: "Check #, ACH trace, etc." %></div>
  <div><%= f.label :notes %><%= f.text_area :notes, rows: 2, class: "border rounded px-2 py-1 w-full" %></div>
  <div class="flex gap-2">
    <%= f.submit "Record payment", class: "bg-emerald-600 text-white px-3 py-1.5 rounded text-sm" %>
    <%= link_to "Cancel", @invoice, class: "border px-3 py-1.5 rounded text-sm" %>
  </div>
<% end %>
