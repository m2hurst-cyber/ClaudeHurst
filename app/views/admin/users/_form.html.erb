<%= form_with model: user, url: (user.persisted? ? admin_user_path(user) : admin_users_path), class: "space-y-3 bg-white p-4 rounded shadow-sm border max-w-xl" do |f| %>
  <% if user.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm">
      <%= user.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div class="grid grid-cols-2 gap-3">
    <div><%= f.label :first_name %><%= f.text_field :first_name, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :last_name %><%= f.text_field :last_name, class: "border rounded px-2 py-1 w-full" %></div>
  </div>
  <div><%= f.label :email %><%= f.email_field :email, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :role %><%= f.select :role, User::ROLES, {}, class: "border rounded px-2 py-1 w-full" %></div>
  <div class="flex items-center gap-2"><%= f.check_box :active %><%= f.label :active, "Active" %></div>
  <div><%= f.label :password, "Password#{user.persisted? ? ' (leave blank to keep)' : ''}" %><%= f.password_field :password, class: "border rounded px-2 py-1 w-full", autocomplete: "new-password" %></div>
  <div><%= f.label :password_confirmation %><%= f.password_field :password_confirmation, class: "border rounded px-2 py-1 w-full", autocomplete: "new-password" %></div>
  <div><%= f.submit class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %></div>
<% end %>
