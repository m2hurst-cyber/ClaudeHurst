<div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
  <div>
    <h1 class="text-2xl font-bold"><%= @user.display_name %></h1>
    <div class="text-sm text-slate-500"><%= @user.email %> · <%= status_badge @user.role %> · <%= @user.active? ? "Active" : "Inactive" %></div>
  </div>
  <div class="flex flex-col gap-2 sm:flex-row">
    <%= link_to "Edit", edit_admin_user_path(@user), class: "rounded border px-3 py-1.5 text-center text-sm" %>
    <% unless @user == current_user %>
      <%= button_to "Delete", admin_user_path(@user), method: :delete, class: "rounded bg-red-600 px-3 py-1.5 text-sm text-white", data: { confirm: "Delete this user?" } %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
  <div class="bg-white border rounded p-4 text-sm">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      <div class="text-slate-500">Sign-ins</div><div><%= @user.sign_in_count %></div>
      <div class="text-slate-500">Last sign-in</div><div><%= @user.current_sign_in_at ? nice_datetime(@user.current_sign_in_at) : "—" %></div>
      <div class="text-slate-500">Owned companies</div><div><%= @user.owned_companies.count %></div>
      <div class="text-slate-500">Owned deals</div><div><%= @user.owned_deals.count %></div>
      <div class="text-slate-500">Assigned tasks</div><div><%= @user.assigned_tasks.count %></div>
    </div>
  </div>
</div>
