<h1 class="text-2xl font-bold mb-4">Audit entry</h1>

<div class="bg-white border rounded p-4 text-sm">
  <div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2">
    <div class="text-slate-500">When</div><div><%= nice_datetime(@log.created_at) %></div>
    <div class="text-slate-500">User</div><div><%= @log.user&.display_name || "system" %></div>
    <div class="text-slate-500">Action</div><div class="font-mono"><%= @log.action %></div>
    <div class="text-slate-500">Subject type</div><div><%= @log.subject_type %></div>
    <div class="text-slate-500">Subject ID</div><div><%= @log.subject_id %></div>
    <div class="text-slate-500">Metadata</div><div><pre class="bg-slate-50 p-2 rounded text-xs overflow-auto"><%= JSON.pretty_generate(@log.metadata || {}) %></pre></div>
  </div>
</div>

<div class="mt-4"><%= link_to "← Back to audit log", admin_audit_logs_path, class: "text-sky-700 text-sm hover:underline" %></div>
