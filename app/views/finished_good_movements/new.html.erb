<h1 class="text-2xl font-bold mb-4">Record movement — Lot <%= @lot.lot_code %></h1>

<%= form_with model: @movement, url: finished_good_lot_finished_good_movements_path(@lot), class: "space-y-3 bg-white p-4 rounded shadow-sm border max-w-xl" do |f| %>
  <% if @movement.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm">
      <%= @movement.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div class="text-sm text-slate-600">On hand: <strong><%= @lot.quantity_on_hand %></strong></div>
  <div><%= f.label :kind %><%= f.select :kind, FinishedGoodMovement::KINDS, {}, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :quantity, "Quantity (positive; ship/scrap auto-negated)" %><%= f.number_field :quantity, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :occurred_at %><%= f.datetime_local_field :occurred_at, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :notes %><%= f.text_area :notes, rows: 2, class: "border rounded px-2 py-1 w-full" %></div>
  <div class="flex gap-2">
    <%= f.submit "Record", class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
    <%= link_to "Cancel", @lot, class: "border px-3 py-1.5 rounded text-sm" %>
  </div>
<% end %>
