<div class="flex justify-between items-start mb-4">
  <div>
    <h1 class="text-2xl font-bold">Run <%= @run.number %></h1>
    <div class="text-sm text-slate-500">
      <%= status_badge @run.status %> · <%= @run.product.display_name %> ·
      Line <%= @run.production_line.code %> · Batch <span class="font-mono"><%= @run.batch_code %></span>
    </div>
  </div>
  <div class="flex gap-2 flex-wrap">
    <% if @run.planned? %>
      <%= link_to "Edit", edit_production_run_path(@run), class: "border px-3 py-1.5 rounded text-sm" %>
      <%= button_to "Release", release_production_run_path(@run), method: :post, class: "bg-sky-600 text-white px-3 py-1.5 rounded text-sm" %>
      <%= button_to "Cancel", cancel_production_run_path(@run), method: :post, class: "bg-slate-500 text-white px-3 py-1.5 rounded text-sm", data: { confirm: "Cancel this run?" } %>
    <% end %>
    <% if @run.released? %>
      <%= button_to "Start", start_run_production_run_path(@run), method: :post, class: "bg-emerald-600 text-white px-3 py-1.5 rounded text-sm" %>
      <%= button_to "Cancel", cancel_production_run_path(@run), method: :post, class: "bg-slate-500 text-white px-3 py-1.5 rounded text-sm", data: { confirm: "Cancel this run?" } %>
    <% end %>
    <% if @run.in_progress? %>
      <%= form_with url: complete_production_run_path(@run), method: :post, class: "flex gap-1" do |f| %>
        <%= number_field_tag :actual_units, @run.planned_units, class: "border rounded px-2 py-1 text-sm w-24", placeholder: "Actual units" %>
        <%= f.submit "Complete", class: "bg-emerald-700 text-white px-3 py-1.5 rounded text-sm" %>
      <% end %>
    <% end %>
    <% if @run.completed? %>
      <%= button_to "Close", close_production_run_path(@run), method: :post, class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
      <%= button_to "Create invoice", create_invoice_production_run_path(@run), method: :post, class: "border px-3 py-1.5 rounded text-sm" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4 mb-4">
  <div class="bg-white border rounded p-3"><div class="text-xs text-slate-500">Planned</div><div class="text-xl font-semibold"><%= @run.planned_units %></div></div>
  <div class="bg-white border rounded p-3"><div class="text-xs text-slate-500">Actual</div><div class="text-xl font-semibold"><%= @run.actual_units || "—" %></div></div>
  <div class="bg-white border rounded p-3"><div class="text-xs text-slate-500">Scheduled start</div><div class="text-sm font-semibold"><%= nice_datetime(@run.scheduled_start) %></div></div>
  <div class="bg-white border rounded p-3"><div class="text-xs text-slate-500">Scheduled end</div><div class="text-sm font-semibold"><%= nice_datetime(@run.scheduled_end) %></div></div>
</div>

<% if @run.notes.present? %>
  <div class="bg-white border rounded p-3 mb-4 text-sm"><%= simple_format @run.notes %></div>
<% end %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="bg-white border rounded p-4">
    <h2 class="font-semibold mb-2">Raw material consumptions</h2>
    <% if @consumptions.any? %>
      <table class="w-full text-sm">
        <thead class="bg-slate-100">
          <tr>
            <th class="px-2 py-1 text-left">Material</th>
            <th class="px-2 py-1 text-left">Lot</th>
            <th class="px-2 py-1 text-right">Qty</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <% @consumptions.each do |c| %>
            <tr>
              <td class="px-2 py-1"><%= c.raw_material_lot.raw_material.name %></td>
              <td class="px-2 py-1 font-mono text-xs"><%= c.raw_material_lot.lot_code %></td>
              <td class="px-2 py-1 text-right"><%= c.quantity_actual || c.quantity_planned %> <%= c.uom %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-slate-500">No consumptions recorded yet. (Release the run to reserve lots.)</p>
    <% end %>
  </div>

  <div class="bg-white border rounded p-4">
    <h2 class="font-semibold mb-2">Finished-good lots</h2>
    <% if @fg_lots.any? %>
      <ul class="text-sm divide-y">
        <% @fg_lots.each do |lot| %>
          <li class="py-1.5 flex justify-between">
            <span><%= link_to lot.lot_code, lot, class: "text-sky-700 hover:underline font-mono" %></span>
            <span class="text-slate-500"><%= lot.quantity_on_hand %>/<%= lot.quantity_produced %> on hand</span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-slate-500">No FG lots yet. (Complete the run to produce.)</p>
    <% end %>
  </div>
</div>
