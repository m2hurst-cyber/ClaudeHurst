<%= form_with model: run, class: "space-y-3 bg-white p-4 rounded shadow-sm border max-w-xl" do |f| %>
  <% if run.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm">
      <%= run.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div><%= f.label :product_id, "Product" %><%= f.collection_select :product_id, Product.active.includes(:company).order(:name), :id, :display_name, { include_blank: true }, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :production_line_id, "Line" %><%= f.collection_select :production_line_id, ProductionLine.active.order(:name), :id, :name, { include_blank: true }, class: "border rounded px-2 py-1 w-full" %></div>
  <div class="grid grid-cols-2 gap-3">
    <div><%= f.label :scheduled_start %><%= f.datetime_local_field :scheduled_start, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :scheduled_end %><%= f.datetime_local_field :scheduled_end, class: "border rounded px-2 py-1 w-full" %></div>
  </div>
  <div><%= f.label :planned_units %><%= f.number_field :planned_units, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :owner_id, "Owner" %><%= f.collection_select :owner_id, User.active, :id, :display_name, { include_blank: true }, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :notes %><%= f.text_area :notes, rows: 3, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.submit class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %></div>
<% end %>
