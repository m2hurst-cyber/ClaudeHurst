<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Production runs</h1>
  <%= link_to "+ Schedule run", new_production_run_path, class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
</div>

<%= form_with url: production_runs_path, method: :get, class: "mb-4 flex gap-2" do |f| %>
  <%= f.select :status, [["All statuses", ""]] + %w[planned released in_progress completed closed cancelled].map { |s| [s.titleize, s] }, { selected: params[:status] }, class: "border rounded px-2 py-1 text-sm" %>
  <%= f.submit "Filter", class: "border px-3 py-1 rounded text-sm" %>
<% end %>

<div class="bg-white rounded shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-100 text-slate-700">
      <tr>
        <th class="px-3 py-2 text-left">Number</th>
        <th class="px-3 py-2 text-left">Product</th>
        <th class="px-3 py-2 text-left">Line</th>
        <th class="px-3 py-2 text-left">Status</th>
        <th class="px-3 py-2 text-left">Scheduled</th>
        <th class="px-3 py-2 text-right">Planned</th>
        <th class="px-3 py-2 text-right">Actual</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @runs.each do |run| %>
        <tr>
          <td class="px-3 py-2 font-mono text-xs"><%= link_to run.number, run, class: "text-sky-700 hover:underline" %></td>
          <td class="px-3 py-2"><%= run.product.display_name %></td>
          <td class="px-3 py-2"><%= run.production_line.code %></td>
          <td class="px-3 py-2"><%= status_badge run.status %></td>
          <td class="px-3 py-2"><%= nice_datetime(run.scheduled_start) %></td>
          <td class="px-3 py-2 text-right"><%= run.planned_units %></td>
          <td class="px-3 py-2 text-right"><%= run.actual_units || "—" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-3"><%== pagy_nav(@pagy) %></div>
