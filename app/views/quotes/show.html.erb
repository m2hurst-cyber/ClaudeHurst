<div class="flex justify-between items-start mb-4">
  <div>
    <h1 class="text-2xl font-bold">Quote <%= @quote.number %></h1>
    <div class="text-sm text-slate-500"><%= status_badge @quote.status %> · <%= link_to @quote.company.name, @quote.company %> · Total <%= money(@quote.total_cents) %></div>
  </div>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_quote_path(@quote), class: "border px-3 py-1.5 rounded text-sm" %>
    <%= link_to "PDF", pdf_quote_path(@quote), class: "border px-3 py-1.5 rounded text-sm", target: "_blank" %>
    <% if @quote.status == "draft" %>
      <%= button_to "Send to customer", send_out_quote_path(@quote), method: :post, class: "bg-emerald-600 text-white px-3 py-1.5 rounded text-sm" %>
    <% end %>
    <% if @quote.status == "sent" %>
      <%= button_to "Mark accepted", mark_accepted_quote_path(@quote), method: :post, class: "bg-emerald-600 text-white px-3 py-1.5 rounded text-sm" %>
      <%= button_to "Mark rejected", mark_rejected_quote_path(@quote), method: :post, class: "bg-red-600 text-white px-3 py-1.5 rounded text-sm" %>
    <% end %>
    <%= button_to "Delete", quote_path(@quote), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-600 text-white px-3 py-1.5 rounded text-sm" %>
  </div>
</div>

<table class="w-full text-sm bg-white border">
  <thead class="bg-slate-100"><tr>
    <th class="px-2 py-1 text-left">Description</th>
    <th class="px-2 py-1 text-right">Qty</th>
    <th class="px-2 py-1 text-right">Unit</th>
    <th class="px-2 py-1 text-right">Line total</th>
  </tr></thead>
  <tbody class="divide-y">
    <% @quote.line_items.each do |li| %>
      <tr>
        <td class="px-2 py-1"><%= li.description %></td>
        <td class="px-2 py-1 text-right"><%= li.quantity %></td>
        <td class="px-2 py-1 text-right"><%= money(li.unit_price_cents) %></td>
        <td class="px-2 py-1 text-right"><%= money(li.line_total_cents) %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot class="bg-slate-50 font-semibold">
    <tr><td colspan="3" class="px-2 py-1 text-right">Subtotal</td><td class="px-2 py-1 text-right"><%= money(@quote.subtotal_cents) %></td></tr>
    <tr><td colspan="3" class="px-2 py-1 text-right">Tax</td><td class="px-2 py-1 text-right"><%= money(@quote.tax_cents) %></td></tr>
    <tr><td colspan="3" class="px-2 py-1 text-right">Total</td><td class="px-2 py-1 text-right"><%= money(@quote.total_cents) %></td></tr>
  </tfoot>
</table>
