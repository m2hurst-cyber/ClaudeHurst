<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Quotes</h1>
  <%= link_to "+ New quote", new_quote_path, class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
</div>
<div class="bg-white rounded shadow-sm border overflow-x-auto">
  <table class="w-full text-sm">
    <thead class="bg-slate-100"><tr>
      <th class="px-3 py-2 text-left">Number</th><th class="px-3 py-2 text-left">Company</th>
      <th class="px-3 py-2 text-left">Status</th><th class="px-3 py-2 text-right">Total</th>
      <th class="px-3 py-2 text-left">Issued</th>
    </tr></thead>
    <tbody class="divide-y">
      <% @quotes.each do |q| %>
        <tr>
          <td class="px-3 py-2"><%= link_to q.number, q, class: "text-sky-700" %></td>
          <td class="px-3 py-2"><%= q.company.name %></td>
          <td class="px-3 py-2"><%= status_badge q.status %></td>
          <td class="px-3 py-2 text-right"><%= money(q.total_cents) %></td>
          <td class="px-3 py-2"><%= nice_date(q.issued_on) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-3"><%== pagy_nav(@pagy) %></div>
