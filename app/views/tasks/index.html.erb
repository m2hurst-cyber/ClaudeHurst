<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Tasks</h1>
  <div class="flex gap-2">
    <%= link_to "Mine", tasks_path(mine: 1), class: "border px-3 py-1.5 rounded text-sm" %>
    <%= link_to "All", tasks_path, class: "border px-3 py-1.5 rounded text-sm" %>
    <%= link_to "+ New", new_task_path, class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
  </div>
</div>
<div class="bg-white rounded shadow-sm border overflow-x-auto">
  <table class="w-full text-sm">
    <thead class="bg-slate-100"><tr>
      <th class="px-3 py-2 text-left">Title</th>
      <th class="px-3 py-2 text-left">Due</th>
      <th class="px-3 py-2 text-left">Assignee</th>
      <th class="px-3 py-2 text-left">Priority</th>
      <th class="px-3 py-2"></th>
    </tr></thead>
    <tbody class="divide-y">
      <% @tasks.each do |t| %>
        <tr>
          <td class="px-3 py-2"><%= link_to t.title, t, class: "text-sky-700" %></td>
          <td class="px-3 py-2 <%= 'text-red-600' if t.due_on && t.due_on < Date.current %>"><%= nice_date(t.due_on) %></td>
          <td class="px-3 py-2"><%= t.assignee&.display_name %></td>
          <td class="px-3 py-2"><%= t.priority %></td>
          <td class="px-3 py-2 text-right">
            <%= button_to "Complete", task_path(t, task: { complete: 1 }), method: :patch, class: "text-xs border px-2 py-0.5 rounded" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-3"><%== pagy_nav(@pagy) %></div>
