<%= form_with model: lot, url: (lot.persisted? ? raw_material_lot_path(lot) : raw_material_raw_material_lots_path(lot.raw_material)), class: "space-y-3 bg-white p-4 rounded shadow-sm border max-w-xl" do |f| %>
  <% if lot.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm">
      <%= lot.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div class="text-sm text-slate-600">Raw material: <strong><%= lot.raw_material.name %></strong> (<%= lot.raw_material.uom %>)</div>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div><%= f.label :lot_code %><%= f.text_field :lot_code, class: "border rounded px-2 py-1 w-full font-mono" %></div>
    <div><%= f.label :supplier %><%= f.text_field :supplier, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :received_on %><%= f.date_field :received_on, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :expires_on %><%= f.date_field :expires_on, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :quantity_received %><%= f.number_field :quantity_received, step: "0.01", class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :quantity_on_hand, "On hand (defaults to received)" %><%= f.number_field :quantity_on_hand, step: "0.01", class: "border rounded px-2 py-1 w-full" %></div>
  </div>
  <div><%= f.label :notes %><%= f.text_area :notes, rows: 2, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.submit class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %></div>
<% end %>
