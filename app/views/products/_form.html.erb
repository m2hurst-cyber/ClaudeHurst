<% form_model = product.persisted? ? product : [company, product] %>

<%= form_with model: form_model, class: "space-y-3 bg-white p-4 rounded shadow-sm border max-w-xl", local: true do |f| %>
  <% if product.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm">
      <%= product.errors.full_messages.to_sentence %>
    </div>
  <% end %>
  <div class="text-sm text-slate-600">Brand: <strong><%= product.company.name %></strong></div>
  <div><%= f.label :sku %><%= f.text_field :sku, class: "border rounded px-2 py-1 w-full font-mono" %></div>
  <div><%= f.label :name %><%= f.text_field :name, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :format %><%= f.text_field :format, class: "border rounded px-2 py-1 w-full", placeholder: "12oz Sleek Can" %></div>
  <div><%= f.label :case_pack %><%= f.number_field :case_pack, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :gtin, "GTIN/UPC" %><%= f.text_field :gtin, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.label :description %><%= f.text_area :description, rows: 3, class: "border rounded px-2 py-1 w-full" %></div>
  <div class="flex items-center gap-2"><%= f.check_box :active %><%= f.label :active, "Active" %></div>
  <div><%= f.submit class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %></div>
<% end %>
