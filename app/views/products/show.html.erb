  subtitle: "Define how the product is built and initiate production.",
  primary_action: link_to("+ Production Run", new_production_run_path(product_id: @product.id), class: "inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white shadow-sm"),
