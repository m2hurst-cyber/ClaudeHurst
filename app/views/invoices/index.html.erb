<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Invoices</h1>
  <%= link_to "+ New invoice", new_invoice_path, class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
</div>
<div class="bg-white rounded shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-100"><tr>
      <th class="px-3 py-2 text-left">Number</th><th class="px-3 py-2 text-left">Company</th>
      <th class="px-3 py-2 text-left">Status</th><th class="px-3 py-2 text-right">Total</th>
      <th class="px-3 py-2 text-right">Balance</th><th class="px-3 py-2 text-left">Due</th>
    </tr></thead>
    <tbody class="divide-y">
      <% @invoices.each do |inv| %>
        <tr>
          <td class="px-3 py-2"><%= link_to inv.number, inv, class: "text-sky-700" %></td>
          <td class="px-3 py-2"><%= inv.company.name %></td>
          <td class="px-3 py-2"><%= status_badge inv.status %></td>
          <td class="px-3 py-2 text-right"><%= money(inv.total_cents) %></td>
          <td class="px-3 py-2 text-right"><%= money(inv.balance_cents) %></td>
          <td class="px-3 py-2"><%= nice_date(inv.due_on) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-3"><%== pagy_nav(@pagy) %></div>
