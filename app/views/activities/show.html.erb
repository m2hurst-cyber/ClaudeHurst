<h1 class="text-2xl font-bold mb-2"><%= @activity.kind.humanize %></h1>
<div class="bg-white border rounded p-4 text-sm space-y-1 max-w-xl">
  <div><strong>When:</strong> <%= nice_datetime @activity.occurred_at %></div>
  <div><strong>Subject:</strong> <%= link_to @activity.subject_type, @activity.subject %></div>
  <div><strong>By:</strong> <%= @activity.user&.display_name %></div>
  <div class="pt-2"><%= simple_format @activity.body %></div>
</div>
