<%= form_with(model: contract, class: "space-y-3 bg-white p-4 rounded shadow-sm border") do |f| %>
  <% if contract.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-2 rounded text-sm"><%= contract.errors.full_messages.to_sentence %></div>
  <% end %>
  <div class="grid grid-cols-2 gap-3">
    <div><%= f.label :company_id %><%= f.collection_select :company_id, Company.kept.by_name, :id, :name, { include_blank: true }, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :title %><%= f.text_field :title, class: "border rounded px-2 py-1 w-full" %></div>
  </div>
  <div class="grid grid-cols-4 gap-3">
    <div><%= f.label :start_on %><%= f.date_field :start_on, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :end_on %><%= f.date_field :end_on, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :payment_terms %><%= f.select :payment_terms, Contract::PAYMENT_TERMS, {}, class: "border rounded px-2 py-1 w-full" %></div>
    <div><%= f.label :minimum_run_units %><%= f.number_field :minimum_run_units, class: "border rounded px-2 py-1 w-full" %></div>
  </div>

  <h3 class="font-semibold mt-2">Pricing tiers</h3>
  <table class="w-full text-sm">
    <thead class="bg-slate-100"><tr><th class="px-2 py-1">Product</th><th class="px-2 py-1">Min qty</th><th class="px-2 py-1">Unit price (cents)</th><th></th></tr></thead>
    <tbody>
      <%= f.fields_for :pricing_tiers do |tf| %>
        <tr>
          <td class="px-1 py-1"><%= tf.collection_select :product_id, Product.kept, :id, :display_name, { include_blank: true }, class: "border rounded px-2 py-1 w-full" %></td>
          <td class="px-1 py-1"><%= tf.number_field :min_quantity, class: "border rounded px-2 py-1 w-full" %></td>
          <td class="px-1 py-1"><%= tf.number_field :unit_price_cents, class: "border rounded px-2 py-1 w-full" %></td>
          <td class="px-1 py-1"><%= tf.check_box :_destroy %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div><%= f.label :terms %><%= f.text_area :terms, rows: 4, class: "border rounded px-2 py-1 w-full" %></div>
  <div><%= f.submit class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %></div>
<% end %>
