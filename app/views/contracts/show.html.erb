<div class="flex justify-between items-start mb-4">
  <div>
    <h1 class="text-2xl font-bold"><%= @contract.title %></h1>
    <div class="text-sm text-slate-500"><%= @contract.number %> · <%= status_badge @contract.status %> · <%= link_to @contract.company.name, @contract.company %></div>
  </div>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_contract_path(@contract), class: "border px-3 py-1.5 rounded text-sm" %>
    <%= link_to "PDF", pdf_contract_path(@contract), class: "border px-3 py-1.5 rounded text-sm", target: "_blank" %>
    <% if @contract.status == "draft" %>
      <%= button_to "Mark signed", mark_signed_contract_path(@contract), method: :post, class: "bg-emerald-600 text-white px-3 py-1.5 rounded text-sm" %>
    <% end %>
    <% if @contract.status == "signed" %>
      <%= button_to "Activate", activate_contract_path(@contract), method: :post, class: "bg-emerald-600 text-white px-3 py-1.5 rounded text-sm" %>
    <% end %>
    <%= button_to "Delete", contract_path(@contract), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-600 text-white px-3 py-1.5 rounded text-sm" %>
  </div>
</div>
<div class="bg-white border rounded p-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2 text-sm mb-4">
  <div>Term: <%= nice_date(@contract.start_on) %> → <%= nice_date(@contract.end_on) %></div>
  <div>Payment: <%= @contract.payment_terms.humanize %></div>
  <div>Min run: <%= @contract.minimum_run_units %> units</div>
  <div>Signed: <%= nice_datetime(@contract.signed_at) %></div>
</div>
<div class="bg-white border rounded p-4 mb-4">
  <h2 class="font-semibold mb-2">Pricing tiers</h2>
  <table class="w-full text-sm">
    <thead class="bg-slate-100"><tr><th class="px-2 py-1 text-left">Product</th><th class="px-2 py-1 text-right">Min qty</th><th class="px-2 py-1 text-right">Unit price</th></tr></thead>
    <tbody class="divide-y">
      <% @contract.pricing_tiers.includes(:product).each do |t| %>
        <tr>
          <td class="px-2 py-1"><%= t.product.display_name %></td>
          <td class="px-2 py-1 text-right"><%= t.min_quantity %></td>
          <td class="px-2 py-1 text-right"><%= money(t.unit_price_cents) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% if @contract.terms.present? %>
<div class="bg-white border rounded p-4"><h2 class="font-semibold mb-2">Terms</h2><%= simple_format @contract.terms %></div>
<% end %>
