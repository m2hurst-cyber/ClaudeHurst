<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Contracts</h1>
  <%= link_to "+ New contract", new_contract_path, class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
</div>
<div class="bg-white rounded shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-100"><tr>
      <th class="px-3 py-2 text-left">Number</th><th class="px-3 py-2 text-left">Title</th>
      <th class="px-3 py-2 text-left">Company</th><th class="px-3 py-2 text-left">Status</th>
      <th class="px-3 py-2 text-left">Term</th>
    </tr></thead>
    <tbody class="divide-y">
      <% @contracts.each do |c| %>
        <tr>
          <td class="px-3 py-2"><%= link_to c.number, c, class: "text-sky-700" %></td>
          <td class="px-3 py-2"><%= c.title %></td>
          <td class="px-3 py-2"><%= c.company.name %></td>
          <td class="px-3 py-2"><%= status_badge c.status %></td>
          <td class="px-3 py-2"><%= nice_date(c.start_on) %> → <%= nice_date(c.end_on) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-3"><%== pagy_nav(@pagy) %></div>
