<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">BOMs for <%= @product.display_name %></h1>
  <%= link_to "+ New BOM", new_product_bom_path(@product), class: "bg-slate-900 text-white px-3 py-1.5 rounded text-sm" %>
</div>

<div class="bg-white rounded shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-100 text-slate-700">
      <tr>
        <th class="px-3 py-2 text-left">Version</th>
        <th class="px-3 py-2 text-left">Active</th>
        <th class="px-3 py-2 text-right">Yield</th>
        <th class="px-3 py-2 text-right">Items</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @boms.each do |bom| %>
        <tr>
          <td class="px-3 py-2"><%= link_to bom.code, bom, class: "text-sky-700 hover:underline" %></td>
          <td class="px-3 py-2"><%= bom.active? ? "Yes" : "No" %></td>
          <td class="px-3 py-2 text-right"><%= bom.yield_units %></td>
          <td class="px-3 py-2 text-right"><%= bom.items.count %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
