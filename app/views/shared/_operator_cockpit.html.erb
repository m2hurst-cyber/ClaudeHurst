<section class="mb-5 rounded-3xl border border-slate-200 bg-white p-4 shadow-sm sm:p-5">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <div class="text-xs font-semibold uppercase tracking-wide text-slate-400">Operator cockpit</div>
      <h2 class="mt-1 text-lg font-semibold text-slate-950"><%= title %></h2>
      <% if local_assigns[:subtitle].present? %>
        <p class="mt-1 max-w-2xl text-sm text-slate-500"><%= subtitle %></p>
      <% end %>
    </div>

    <% if local_assigns[:primary_action].present? %>
      <div class="flex shrink-0">
        <%= primary_action %>
      </div>
    <% end %>
  </div>

  <% if local_assigns[:actions].present? %>
    <div class="mt-4 grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
      <% actions.each do |action| %>
        <%= action %>
      <% end %>
    </div>
  <% end %>
</section>
