<div data-controller="mobile-drawer">
  <div data-mobile-drawer-target="backdrop" data-action="click->mobile-drawer#close" class="fixed inset-0 z-40 hidden bg-black/40 backdrop-blur-sm lg:hidden"></div>

  <aside data-mobile-drawer-target="panel" class="fixed inset-y-0 left-0 z-50 w-64 -translate-x-full transform bg-slate-900 text-slate-200 transition-transform duration-200 ease-out lg:translate-x-0 lg:static lg:flex">
    <div class="flex w-full flex-col">
      <div class="border-b border-slate-800 px-5 py-4">
        <%= link_to root_path, class: "text-lg font-bold text-white" do %>
          Great Southern Copacker
        <% end %>
        <div class="text-xs text-slate-400">Co-pack CRM · ERP</div>
      </div>

      <nav class="flex-1 overflow-y-auto p-3 text-sm">
        <div class="px-2 pt-3 pb-1 text-xs uppercase text-slate-500">CRM</div>
        <%= link_to "Dashboard", root_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Companies", companies_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Deals", deals_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Pipeline", pipeline_deals_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Tasks", tasks_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Reminders", reminders_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>

        <div class="px-2 pt-3 pb-1 text-xs uppercase text-slate-500">Sales</div>
        <%= link_to "Quotes", quotes_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Contracts", contracts_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Invoices", invoices_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>

        <div class="px-2 pt-3 pb-1 text-xs uppercase text-slate-500">Production</div>
        <%= link_to "Products", products_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Runs", production_runs_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Lines", production_lines_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Raw materials", raw_materials_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
        <%= link_to "Finished goods", finished_good_lots_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>

        <% if current_user&.admin? %>
          <div class="px-2 pt-3 pb-1 text-xs uppercase text-slate-500">Admin</div>
          <%= link_to "Users", admin_users_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
          <%= link_to "Audit log", admin_audit_logs_path, class: "block rounded px-2 py-2 hover:bg-slate-800" %>
          <%= link_to "Jobs", "/jobs", class: "block rounded px-2 py-2 hover:bg-slate-800" %>
          <% if Rails.env.development? %>
            <%= link_to "Mail inbox", "/letter_opener", class: "block rounded px-2 py-2 hover:bg-slate-800" %>
          <% end %>
        <% end %>
      </nav>
    </div>
  </aside>
</div>
