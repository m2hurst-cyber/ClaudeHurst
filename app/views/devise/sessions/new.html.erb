<div class="w-full max-w-5xl px-6 py-10 lg:grid lg:grid-cols-[1.1fr_0.9fr] lg:gap-10 lg:items-center">
  <section class="hidden rounded-3xl bg-slate-900 px-10 py-12 text-white shadow-2xl lg:block">
    <%= render "shared/brand_lockup",
      stacked: true,
      wrapper_class: "items-start text-left",
      title_class: "text-3xl font-semibold tracking-tight",
      tagline_class: "mt-2 text-sm uppercase tracking-[0.2em] text-sky-200",
      image_class: "h-24 w-24" %>
    <p class="mt-10 max-w-md text-sm leading-7 text-slate-300">
      Manage CRM, contracts, production, invoicing, and fulfillment from one operating system built for beverage manufacturing.
    </p>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-8 shadow-xl shadow-slate-200/70 sm:p-10">
    <div class="mb-8 flex justify-center lg:hidden">
      <%= render "shared/brand_lockup",
        stacked: true,
        title_class: "mt-3 text-2xl font-semibold tracking-tight text-slate-900",
        tagline_class: "mt-2 text-xs uppercase tracking-[0.2em] text-slate-500",
        image_class: "h-20 w-20" %>
    </div>

    <div class="mb-6">
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Sign in</h1>
      <p class="mt-2 text-sm text-slate-500">Use your work account to access <%= Branding.company_name %>.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
      </div>

      <div>
        <div class="mb-2 flex items-center justify-between gap-4">
          <%= f.label :password, class: "block text-sm font-medium text-slate-700" %>
          <% if devise_mapping.recoverable? %>
            <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-sm font-medium text-sky-700 hover:text-sky-900" %>
          <% end %>
        </div>
        <%= f.password_field :password, autocomplete: "current-password", class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-3 text-sm text-slate-600">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-sky-700 focus:ring-sky-200" %>
          <span>Remember me</span>
        </label>
      <% end %>

      <%= f.submit "Sign in", class: "inline-flex w-full items-center justify-center rounded-xl bg-sky-700 px-4 py-3 text-sm font-semibold text-white transition hover:bg-sky-800 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:ring-offset-2" %>
    <% end %>
  </section>
</div>