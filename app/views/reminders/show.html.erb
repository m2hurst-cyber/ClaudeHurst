<div class="flex justify-between items-start mb-4">
  <h1 class="text-2xl font-bold">Reminder</h1>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_reminder_path(@reminder), class: "border px-3 py-1.5 rounded text-sm" %>
    <%= button_to "Delete", reminder_path(@reminder), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-600 text-white px-3 py-1.5 rounded text-sm" %>
  </div>
</div>
<div class="bg-white border rounded p-4 text-sm max-w-xl space-y-1">
  <div>Remind at: <%= nice_datetime(@reminder.remind_at) %></div>
  <div>Channel: <%= @reminder.channel %></div>
  <div>Recurrence: <%= @reminder.recurrence %></div>
  <div>Fired: <%= @reminder.fired? ? nice_datetime(@reminder.fired_at) : "pending" %></div>
  <div class="pt-2"><%= @reminder.message %></div>
</div>
