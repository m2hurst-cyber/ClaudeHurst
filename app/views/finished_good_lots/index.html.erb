<h1 class="text-2xl font-bold mb-4">Finished-good lots</h1>

<div class="bg-white rounded shadow-sm border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-100 text-slate-700">
      <tr>
        <th class="px-3 py-2 text-left">Lot code</th>
        <th class="px-3 py-2 text-left">Product</th>
        <th class="px-3 py-2 text-left">Produced</th>
        <th class="px-3 py-2 text-left">Best by</th>
        <th class="px-3 py-2 text-right">Produced qty</th>
        <th class="px-3 py-2 text-right">On hand</th>
      </tr>
    </thead>
    <tbody class="divide-y">
      <% @lots.each do |lot| %>
        <tr>
          <td class="px-3 py-2 font-mono text-xs"><%= link_to lot.lot_code, lot, class: "text-sky-700 hover:underline" %></td>
          <td class="px-3 py-2"><%= lot.product.display_name %></td>
          <td class="px-3 py-2"><%= nice_date(lot.produced_on) %></td>
          <td class="px-3 py-2"><%= nice_date(lot.best_by_on) %></td>
          <td class="px-3 py-2 text-right"><%= lot.quantity_produced %></td>
          <td class="px-3 py-2 text-right"><%= lot.quantity_on_hand %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-3"><%== pagy_nav(@pagy) %></div>
