<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold">Notifications</h1>
  <%= button_to "Mark all read", mark_all_read_notifications_path, method: :post, class: "border px-3 py-1.5 rounded text-sm" %>
</div>
<div class="bg-white border rounded divide-y">
  <% @notifications.each do |n| %>
    <div class="p-3 flex items-start justify-between <%= 'bg-sky-50' unless n.read? %>">
      <div>
        <div class="font-medium"><%= n.title %></div>
        <div class="text-sm text-slate-600"><%= n.body %></div>
        <div class="text-xs text-slate-400"><%= time_ago_in_words(n.created_at) %> ago</div>
      </div>
      <div class="flex gap-2">
        <% unless n.read? %>
          <%= button_to "Mark read", notification_path(n), method: :patch, class: "text-xs border px-2 py-0.5 rounded" %>
        <% end %>
        <% if n.url.present? %>
          <%= link_to "Open", n.url, class: "text-xs border px-2 py-0.5 rounded" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
<div class="mt-3"><%== pagy_nav(@pagy) %></div>
