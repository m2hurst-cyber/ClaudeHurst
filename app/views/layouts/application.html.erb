<!DOCTYPE html>
<html>
  <head>
    <title>Great Southern Copacker</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-100 text-slate-900 antialiased">
    <% if user_signed_in? %>
      <div class="min-h-screen lg:flex">
        <%= render "shared/sidebar" %>
        <div class="min-w-0 flex-1 lg:pl-64">
          <%= render "shared/topbar" %>
          <main class="mx-auto w-full max-w-7xl px-4 py-5 pb-24 sm:px-6 lg:px-8 lg:py-8 lg:pb-8">
            <%= render "shared/flash" %>
            <%= yield %>
          </main>
        </div>
        <%= render "shared/mobile_bottom_nav" %>
      </div>
    <% else %>
      <main class="flex min-h-screen items-center justify-center bg-gradient-to-br from-slate-950 via-slate-900 to-slate-800 px-4 py-10">
        <div class="w-full max-w-md">
          <%= render "shared/flash" %>
          <%= yield %>
        </div>
      </main>
    <% end %>
  </body>
</html>
