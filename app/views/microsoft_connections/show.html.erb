<div class="mx-auto max-w-3xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900">Microsoft connection</h1>
    <p class="mt-2 text-sm text-slate-600">
      Connect Outlook and Teams so ClaudeHurst can push meetings, customer emails, reminders, and operational alerts continuously.
    </p>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <% if @microsoft_connection&.connected? %>
      <div class="space-y-3">
        <div>
          <p class="text-sm font-medium text-slate-500">Connected account</p>
          <p class="mt-1 text-lg font-semibold text-slate-900"><%= @microsoft_connection.display_name.presence || @microsoft_connection.email %></p>
          <p class="text-sm text-slate-500"><%= @microsoft_connection.email %></p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <div class="rounded-xl bg-slate-50 p-4">
            <p class="text-xs uppercase tracking-wide text-slate-500">Tenant</p>
            <p class="mt-1 text-sm text-slate-900"><%= @microsoft_connection.tenant_id %></p>
          </div>
          <div class="rounded-xl bg-slate-50 p-4">
            <p class="text-xs uppercase tracking-wide text-slate-500">Expires</p>
            <p class="mt-1 text-sm text-slate-900"><%= l(@microsoft_connection.integration_expires_at, format: :short) if @microsoft_connection.integration_expires_at %></p>
          </div>
        </div>

        <%= button_to "Disconnect Microsoft", microsoft_connection_path, method: :delete, class: "rounded-xl border border-red-200 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50" %>
      </div>
    <% else %>
      <div class="space-y-4">
        <p class="text-sm text-slate-600">
          No Microsoft account is connected yet. Connect one to enable Outlook calendar creation, Outlook delivery, and Teams channel notifications.
        </p>
        <%= button_to "Connect Microsoft", microsoft_connection_path, method: :post, class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700" %>
      </div>
    <% end %>
  </div>
</div>
